# LibertyMind Environment Variables
# ===================================
# Copy this file to .env and fill in your API keys.
# NEVER commit your .env file to version control.

# ---- Cloud AI Provider Keys ----
# At least one cloud provider key is required for cloud-based chat/introspection.

# OpenAI (required for openai provider)
OPENAI_API_KEY=

# Anthropic (required for anthropic provider)
ANTHROPIC_API_KEY=

# Google Gemini (required for gemini provider)
GOOGLE_API_KEY=

# Groq (required for groq provider)
GROQ_API_KEY=

# Mistral (required for mistral provider)
MISTRAL_API_KEY=

# Together AI (required for together provider)
TOGETHER_API_KEY=

# HuggingFace (required for huggingface provider)
HUGGINGFACE_API_KEY=

# Cohere (required for cohere provider)
COHERE_API_KEY=

# ---- Local AI Providers ----
# No API keys required. The following providers are detected automatically
# by scanning common local ports:
#   Ollama       -> http://localhost:11434
#   LM Studio    -> http://localhost:1234/v1
#   vLLM         -> http://localhost:8000/v1
#   llama.cpp    -> http://localhost:8080/v1
#   KoboldCPP    -> http://localhost:5001/v1
#   Oobabooga    -> http://localhost:5000/v1

# ---- Proxy Server ----
# Used by the FastAPI proxy server (libertymind serve).
# OPENAI_API_KEY is reused as the upstream API key by default.

# ---- Optional ----
# Custom OpenAI-compatible endpoint URL (for the "custom" provider)
# LIBERTYMIND_CUSTOM_BASE_URL=
